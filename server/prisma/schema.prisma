generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())
  category     Category?
  dob          DateTime?
  location     String?
  memberId     String        @unique
  memberTier   MemberTier    @default(FREE)
  mobileNumber String?
  name         String?
  pwd          Boolean?
  testAttempts TestAttempt[]
}

model Subject {
  id     String  @id @default(uuid())
  name   String  @unique
  topics Topic[]
}

model Topic {
  id            String     @id @default(uuid())
  name          String
  subjectId     String
  parentTopicId String?
  questions     Question[]
  parentTopic   Topic?     @relation("SubTopics", fields: [parentTopicId], references: [id])
  subTopics     Topic[]    @relation("SubTopics")
  subject       Subject    @relation(fields: [subjectId], references: [id])
}

model Question {
  id          String     @id @default(uuid())
  text        String
  imageUrl    String?
  difficulty  Difficulty
  explanation String?
  topicId     String
  options     Option[]
  topic       Topic      @relation(fields: [topicId], references: [id])
  responses   Response[]
  tests       Test[]     @relation("TestQuestions")
}

model Option {
  id         String     @id @default(uuid())
  text       String
  isCorrect  Boolean    @default(false)
  questionId String
  question   Question   @relation(fields: [questionId], references: [id])
  responses  Response[]
}

model Test {
  id             String        @id @default(uuid())
  title          String
  duration       Int
  totalQuestions Int
  isPublished    Boolean       @default(false)
  createdAt      DateTime      @default(now())
  year           Int?
  date           DateTime?
  attempts       TestAttempt[]
  questions      Question[]    @relation("TestQuestions")
}

model TestAttempt {
  id         String     @id @default(uuid())
  userId     String
  testId     String
  startTime  DateTime   @default(now())
  submitTime DateTime?
  score      Float?
  status     String     @default("ONGOING")
  responses  Response[]
  test       Test       @relation(fields: [testId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
}

model Response {
  id               String      @id @default(uuid())
  attemptId        String
  questionId       String
  selectedOptionId String
  isCorrect        Boolean
  timeTaken        Int?
  markedForReview  Boolean     @default(false)
  attempt          TestAttempt @relation(fields: [attemptId], references: [id])
  question         Question    @relation(fields: [questionId], references: [id])
  selectedOption   Option      @relation(fields: [selectedOptionId], references: [id])
}

enum Role {
  USER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Category {
  GEN
  EWS
  OBC
  SC
  ST
}

enum MemberTier {
  FREE
  PRO
  MAX
}
